#!/bin/sh
# SPDX-License-Identifier: LGPL-2.1+

set -eu
[ -n "${DEBUG:-}" ] && set -x

. "$(dirname "$0")/lib.sh"

check_requirements

if [ -z "${LXCFS_TEST_IN_CT:-}" ]; then
	# Test requires at least 256 MiB of swap to function
	system_swap_size=$(awk '/^SwapTotal:/ { print $2 }' /proc/meminfo)
	[ "$system_swap_size" -ge "$((256 * 1024))" ] || { echo "Error: swap < 256 MiB" >&2; exit 1; }
fi

LXCFSDIR=${LXCFSDIR:-/var/lib/lxcfs}

#
# We are going to make the following cgroup tree:
# root
#   |
#   |_ cg1 (+memory, limit 500 MiB, swap 256 MiB)
#       |
#       |_ cg2 (+memory, limit 600 MiB, swap 300 MiB)
#           |
#           |_ cg3 (+memory, limit max, cgroup namespace root cgroup)
#               |
#               |_ init.scope -> init process
#               |
#               |_ cg4 (+memory, limit 400 MiB, swap 200 MiB)
#                   |
#                   |_ cg5 (+memory, limit max)
#                       |
#                       |_ cg6 (+memory, limit 900 MiB, swap 450 MiB)
#                           |
#                           |_ cg7 -> process requesting ${LXCFSDIR}/proc/meminfo
#
# This tree mimics what we can have with systemd & system container.
#
# LXCFS should completely ignore everything under cg3, and then go up the tree
# and determine that effective memory limit for the container is 500 MiB.
#
# To achive this for process sitting in cg7, LXCFS should:
# 1. Find init process of the container
# 2. Determine its cgroup (cg1/cg2/cg3/init.scope)
# 3. Find container's cgroup (cg1/cg2/cg3)
# 4. Go up the tree and find minimal limit -> 500 MiB
#

init_cgroups

cleanup() {
	clean_cgroups

	if [ $FAILED -eq 1 ]; then
		exit 1
	fi
	exit 0
}

FAILED=1
trap cleanup EXIT HUP INT TERM

cgroups_setup_callback() {
	# Configure cgroup limits from the "host" side
	echo $((500*256*4096)) > "/sys/fs/cgroup/${cg1}/memory.max"
	echo $((256*256*4096)) > "/sys/fs/cgroup/${cg1}/memory.swap.max"
	echo '+memory' > "/sys/fs/cgroup/${cg1}/cgroup.subtree_control"

	echo $((600*256*4096)) > "/sys/fs/cgroup/${cg1}/${cg2}/memory.max"
	echo $((300*256*4096)) > "/sys/fs/cgroup/${cg1}/${cg2}/memory.swap.max"
	echo '+memory' > "/sys/fs/cgroup/${cg1}/${cg2}/cgroup.subtree_control"
}

#
# This will create MNT/PID/CGROUP namespaces and re-execute (!) current script
# inside.
#
setup_container cgroups_setup_callback

#
# If we reach this point, it means that current process is sitting in
# PID/MNT/CGROUP namespace and "root" cgroup is /sys/fs/cgroup/${cg1}/${cg2}/${cg3}
# Now we need to unmount host cgroupfs and mount our own to see cgroup-namespaced
# cgroupfs view.
#

umount -l /sys/fs/cgroup
mount -t cgroup2 cgroup2 -o nsdelegate,memory_recursiveprot /sys/fs/cgroup

# Let's move init process to the init.scope cgroup.
# We can't keep init process in the root cgroup (cg1/cg2/cg3), because
# we can't enable memory controller in it until there is a process sitting.
# See "No Internal Process Constraint" rule in kernel doc.
mkdir "/sys/fs/cgroup/init.scope"
echo 1 > "/sys/fs/cgroup/init.scope/cgroup.procs"
# Finally, we can enable memory controller in root cgroup of the container (cg1/cg2/cg3)
cat /sys/fs/cgroup/cgroup.procs
echo '+memory' > "/sys/fs/cgroup/cgroup.subtree_control"

echo $((400*256*4096)) > "/sys/fs/cgroup/${cg4}/memory.max"
echo $((200*256*4096)) > "/sys/fs/cgroup/${cg4}/memory.swap.max"
echo '+memory' > "/sys/fs/cgroup/${cg4}/cgroup.subtree_control"

# no limit on cg5
echo '+memory' > "/sys/fs/cgroup/${cg4}/${cg5}/cgroup.subtree_control"

echo $((900*256*4096)) > "/sys/fs/cgroup/${cg4}/${cg5}/${cg6}/memory.max"
echo $((450*256*4096)) > "/sys/fs/cgroup/${cg4}/${cg5}/${cg6}/memory.swap.max"
echo '+memory' > "/sys/fs/cgroup/${cg4}/${cg5}/${cg6}/cgroup.subtree_control"

echo "==> Reading /proc/meminfo from init process's cgroup"

# awk sits in the same cgroup as init process
mem_total_init=$(awk '/^MemTotal:/ { print $2 }' "${LXCFSDIR}/proc/meminfo")
swap_total_init_meminfo=$(awk '/^SwapTotal:/ { print $2 }' "${LXCFSDIR}/proc/meminfo")
swap_total_init_swaps=$(awk 'NR > 1 { print $3 }' "${LXCFSDIR}/proc/swaps")

echo "==> Confirming that limit is correct"
# While a limit on the container's root cgroup
# is set too "max", we expect to get 500 MiB, because LXCFS
# goes up the cgroup tree and tries to find a minimal value.
[ "$mem_total_init" -eq 512000 ]
[ "$swap_total_init_meminfo" -eq 262144 ]
[ "$swap_total_init_swaps" -eq 262144 ]

echo "==> Testing /proc/meminfo with sub-cgroup"

# A process, requesting asking LXCFS will be sitting in some nested
# cgroup *under* cg3 (like it usually happens in systemd-based systems).
mem_total_ct_process=$(do_in_cg "/sys/fs/cgroup/${cg4}/${cg5}/${cg6}/${cg7}" awk '/^MemTotal:/ { print $2 }' "${LXCFSDIR}/proc/meminfo")
swap_total_ct_process_meminfo=$(do_in_cg "/sys/fs/cgroup/${cg4}/${cg5}/${cg6}/${cg7}" awk '/^SwapTotal:/ { print $2 }' "${LXCFSDIR}/proc/meminfo")
swap_total_ct_process_swaps=$(do_in_cg "/sys/fs/cgroup/${cg4}/${cg5}/${cg6}/${cg7}" awk 'NR > 1 { print $3 }' "${LXCFSDIR}/proc/swaps")

#shell_breakpoint

echo "==> Confirming same limits"
[ "$mem_total_init" -eq "$mem_total_ct_process" ]
[ "$swap_total_ct_process_meminfo" -eq "$swap_total_ct_process_swaps" ]
[ "$swap_total_init_meminfo" -eq "$swap_total_ct_process_meminfo" ]

FAILED=0
